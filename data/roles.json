  "guidelines": [
    {
      "section": "Products management",
      "guideline": "Restock and clean the bench after use (EtOH sanitization, empty tip bins).",
      "order": 1
    },
    {
      "section": "Products management",
      "guideline": "Empty the liquid waste container once it reaches the fill line.",
      "order": 2
    },
    {
      "section": "Products management",
      "guideline": "HI-FBS: Thaw at 37°C, heat-inactivate at 60°C for 30 minutes, then aliquot.",
      "order": 3
    },
    {
      "section": "Reagent & Buffer Preparation",
      "guideline": "Refill 1X buffers immediately after use.",
      "order": 1
    },
    {
      "section": "Reagent & Buffer Preparation",
      "guideline": "Notify the person in charge if 10X buffer stocks are low.",
      "order": 2
    },
    {
      "section": "Reagent & Buffer Preparation",
      "guideline": "Inform the person in charge in advance when using consumables in bulk.",
      "order": 3
    },
    {
      "section": "Reagent & Buffer Preparation",
      "guideline": "Contact the person in charge in advance if aliquoting is required.",
      "order": 4
    }
  ],
